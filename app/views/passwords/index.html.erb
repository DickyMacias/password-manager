<h1 class="text-3xl font-bold text-center text-gray-800 mb-8">Your Saved Passwords</h1>

<div data-controller="search" data-search-url-value="<%= passwords_path %>" data-search-min-length-value="3" class="mb-6">
  <div class="flex justify-between items-start">
    <div>
      <%= link_to "Add New Password", new_password_path, class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 transition-colors" %>
    </div>
    
    <div class="relative">
      <div class="flex items-center">
        <div class="relative mr-2">
          <!-- Spinner - Hidden by default, positioned outside the input -->
          <div data-search-target="spinner" class="hidden">
            <svg class="animate-spin h-4 w-4 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </div>
        </div>
        
        <input
          type="text"
          name="search"
          placeholder="Search passwords..."
          value="<%= params[:search] %>"
          class="px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-1 focus:ring-indigo-500"
          data-search-target="input"
          data-action="input->search#search keyup->search#search"
          autocomplete="off"
        >
        
        <% if params[:search].present? %>
          <button data-action="click->search#clearSearch" class="ml-2 px-2 py-1 text-sm text-gray-600 hover:text-gray-900 border border-gray-300 rounded-md">
            Clear
          </button>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div id="password_results" data-search-target="results">
  <%= render 'password_list' %>
</div>
