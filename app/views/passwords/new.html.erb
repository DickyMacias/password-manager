<h1 class="text-3xl font-bold text-center text-gray-800 mb-8">Add New Password</h1>

<div class="bg-white p-8 rounded-lg shadow-md max-w-md mx-auto">
  <%= form_with(model: @password, html: { class: "space-y-6" }) do |f| %>
    <% if @password.errors.any? %>
      <div class="bg-red-50 text-red-700 p-4 rounded-md mb-6 border-l-4 border-red-500">
        <h2 class="text-lg font-medium mb-2">
          <%= pluralize(@password.errors.count, "error") %> prohibited this password from being saved:
        </h2>
        <ul class="list-disc pl-5 space-y-1">
          <% @password.errors.full_messages.each do |message| %>
            <li class="text-sm"><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-2">
      <%= f.label :website, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :website, class: "mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="space-y-2">
      <%= f.label :service_url, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :service_url, class: "mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>
    
    <% # El campo username se establece automáticamente en el controlador %>
    <%= f.hidden_field :username, value: current_user.email %>

    <div class="space-y-2">
      <%= f.label :password_digest, "Password", class: "block text-sm font-medium text-gray-700" %>
      <%= f.password_field :password_digest, class: "mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="space-y-2">
      <%= f.label :notes, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :notes, rows: 3, class: "mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="flex items-center justify-between">
      <%= link_to "Cancel", passwords_path, class: "text-sm text-gray-600 hover:text-gray-500" %>
      <%= f.submit "Save Password", class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  <% end %>
</div>
