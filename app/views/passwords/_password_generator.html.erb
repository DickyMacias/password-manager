<%# Partial for the password generator %>

<div class="bg-white shadow rounded-lg p-6 mb-6" data-controller="password-generator" data-password-generator-target-field-value="#password_password_digest">
  <h3 class="text-lg font-medium text-gray-900 mb-4">Password Generator</h3>
  
  <div class="mb-4">
    <label for="generated-password" class="block text-gray-700 font-medium mb-2">Generated password:</label>
    <div class="flex">
      <input type="text" id="generated-password" data-password-generator-target="output" readonly 
             class="shadow-sm block w-full border-gray-300 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md">
      <button type="button" data-action="click->password-generator#copyToClipboard"
              class="ml-2 inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
        Copy
      </button>
    </div>
  </div>

  <div class="mb-4">
    <label for="password-length" class="block text-gray-700 font-medium mb-2">
      Length: <span data-password-generator-target="lengthValue">16</span>
    </label>
    <input type="range" id="password-length" min="8" max="32" data-password-generator-target="length" 
           data-action="input->password-generator#updateLengthValue"
           class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">
  </div>

  <div class="grid grid-cols-2 gap-4 mb-4">
    <div>
      <div class="flex items-center mb-2">
        <input type="checkbox" id="lowercase-chars" data-password-generator-target="lowercase" checked
               class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
        <label for="lowercase-chars" class="ml-2 block text-sm text-gray-700">Lowercase (a-z)</label>
      </div>
      <div class="flex items-center">
        <input type="checkbox" id="uppercase-chars" data-password-generator-target="uppercase" checked
               class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
        <label for="uppercase-chars" class="ml-2 block text-sm text-gray-700">Uppercase (A-Z)</label>
      </div>
    </div>
    <div>
      <div class="flex items-center mb-2">
        <input type="checkbox" id="number-chars" data-password-generator-target="numbers" checked
               class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
        <label for="number-chars" class="ml-2 block text-sm text-gray-700">Numbers (0-9)</label>
      </div>
      <div class="flex items-center">
        <input type="checkbox" id="symbol-chars" data-password-generator-target="symbols" checked
               class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
        <label for="symbol-chars" class="ml-2 block text-sm text-gray-700">Symbols (!@#$...)</label>
      </div>
    </div>
  </div>

  <div class="flex space-x-2">
    <button type="button" data-action="click->password-generator#generate"
            class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
      Generate New Password
    </button>
    
    <button type="button" data-action="click->password-generator#usePassword"
            class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
      Use This Password
    </button>
  </div>
</div>
